# Auto-detect text files and normalize line endings
* text=auto

# Force LF for source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf

# Shell scripts must use LF (CRLF breaks them)
*.sh text eol=lf

# Python
*.py text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.mp3 binary
*.pdf binary
